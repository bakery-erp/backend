// Bakery ERP - Full schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  BAKER
  CASHIER
  SAMBUSA_WORKER
}

enum Shift {
  DAY
  NIGHT
}

enum CategoryType {
  PRODUCED
  RESELL
}

enum UnitType {
  PIECE
  KG
  LITER
}

enum BatchStatus {
  STARTED
  COMPLETED
}

enum SessionStatus {
  OPEN
  CLOSED
}

enum PaymentMethod {
  CASH
  MOBILE_BANKING
}

enum SupplierType {
  INJERA
  MILK
  GENERAL
}

enum LoanType {
  EMPLOYEE
  CUSTOMER
}

enum LoanStatus {
  OPEN
  PAID
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  PRODUCTION_USAGE
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  users     User[]
  stockItems StockItem[]
  productionBatches ProductionBatch[]
  productConversions ProductConversion[]
  dailySessions DailySession[]
  suppliers Supplier[]
  expenses Expense[]
  loans Loan[]
}

model User {
  id            String    @id @default(cuid())
  fullName      String
  phone         String?   @unique   // Login and identity (required for new users; set for existing to allow login)
  passwordHash  String
  role          Role      // OWNER/ADMIN = more privileges; BAKER, CASHIER, SAMBUSA_WORKER = staff
  branchId      String?
  isActive      Boolean   @default(true)
  // Salary / billing (all users are staff; optional for OWNER/ADMIN if not paid via payroll)
  salary        Decimal?  @db.Decimal(12, 2)
  startDate     DateTime?
  lastPaidDate  DateTime?
  shift         Shift?
  filesUrl      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  branch        Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  stockMovements StockMovement[]
  productionBatches ProductionBatch[]
  productConversions ProductConversion[]
  sales Sale[]
  expenses Expense[]
  penalties     Penalty[]
  payrollRecords PayrollRecord[]
  loansAsBorrower Loan[]  @relation("EmployeeLoans")
}

model ProductCategory {
  id   String @id @default(cuid())
  name String
  type CategoryType
  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  categoryId  String
  category    ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name        String
  flavor      String?
  unitType    UnitType
  basePrice   Decimal  @db.Decimal(12, 2)
  buyPrice    Decimal? @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  productionItems ProductionItem[]
  saleItems   SaleItem[]
  leftoverRecords LeftoverRecord[]
  supplierDeliveries SupplierDelivery[]
  conversionsFrom ProductConversion[] @relation("FromProduct")
  conversionsTo   ProductConversion[] @relation("ToProduct")
}

model StockItem {
  id              String   @id @default(cuid())
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name            String
  unitType        UnitType
  currentQuantity Decimal  @db.Decimal(12, 3)
  minStockLevel   Decimal? @db.Decimal(12, 3)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  movements       StockMovement[]
  productionMaterialUsages ProductionMaterialUsage[]
  supplierDeliveries SupplierDelivery[]

  @@index([branchId])
}

model StockMovement {
  id          String            @id @default(cuid())
  stockItemId String
  stockItem   StockItem         @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  quantity    Decimal           @db.Decimal(12, 3)
  type        StockMovementType
  reason      String?
  createdAt   DateTime          @default(now())

  @@index([stockItemId])
  @@index([userId])
  @@index([createdAt])
}

model ProductionBatch {
  id        String      @id @default(cuid())
  branchId  String
  branch    Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  date      DateTime    @db.Date   @default(dbgenerated("(CURDATE())"))  // Day this production is for (flexible; can be past)
  shift     Shift?
  status    BatchStatus @default(STARTED)
  createdAt DateTime    @default(now())
  items     ProductionItem[]
  materialUsages ProductionMaterialUsage[]

  @@index([branchId, date])
  @@index([branchId, status])
}

model ProductionItem {
  id                String          @id @default(cuid())
  batchId           String
  batch             ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  productId         String
  product           Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantityProduced  Int
  createdAt         DateTime        @default(now())
}

model ProductionMaterialUsage {
  id          String          @id @default(cuid())
  batchId     String
  batch       ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  stockItemId String
  stockItem   StockItem       @relation(fields: [stockItemId], references: [id], onDelete: Restrict)
  quantityUsed Decimal        @db.Decimal(12, 3)
  createdAt   DateTime       @default(now())
}

model ProductConversion {
  id            String   @id @default(cuid())
  branchId      String
  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  fromProductId String
  fromProduct   Product  @relation("FromProduct", fields: [fromProductId], references: [id], onDelete: Restrict)
  toProductId   String
  toProduct     Product  @relation("ToProduct", fields: [toProductId], references: [id], onDelete: Restrict)
  fromQuantity  Int
  toQuantity    Int
  createdAt     DateTime @default(now())
}

model DailySession {
  id           String        @id @default(cuid())
  branchId     String
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  date         DateTime      @db.Date   // Calendar day; opens at 00:00, ends after 24h; can register for any day (incl. past)
  status       SessionStatus @default(OPEN)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sales        Sale[]
  leftoverRecords LeftoverRecord[]
  @@unique([branchId, date])
}

model Sale {
  id            String    @id @default(cuid())
  sessionId     String
  session       DailySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  totalAmount   Decimal   @db.Decimal(12, 2)
  paymentMethod PaymentMethod @default(CASH)
  createdAt     DateTime  @default(now())
  items         SaleItem[]

  @@index([sessionId])
  @@index([userId])
  @@index([createdAt])
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int
  unitPrice Decimal  @db.Decimal(12, 2)
  subtotal  Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([productId])
}

model LeftoverRecord {
  id               String        @id @default(cuid())
  sessionId        String
  session          DailySession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  productId        String
  product          Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantityRemaining Int
  recordedAt       DateTime      @default(now())
  @@unique([sessionId, productId])
}

model Supplier {
  id        String   @id @default(cuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name      String
  phone     String?
  type      SupplierType
  createdAt DateTime @default(now())
  deliveries SupplierDelivery[]
}

model SupplierDelivery {
  id               String     @id @default(cuid())
  supplierId       String
  supplier         Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  productId        String
  product          Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  stockItemId      String?    // When set, creates a stock IN movement for this item
  stockItem        StockItem? @relation(fields: [stockItemId], references: [id], onDelete: SetNull)
  quantityReceived Int
  unitBuyPrice     Decimal    @db.Decimal(12, 2)
  unitSellPrice   Decimal    @db.Decimal(12, 2)
  isPaid           Boolean    @default(false)
  returnedQuantity Int        @default(0)
  createdAt        DateTime   @default(now())

  @@index([supplierId])
  @@index([createdAt])
}

enum ExpenseType {
  OPERATIONAL  // Rent, utilities, supplies, etc.
  PERSONAL     // Personal/other
}

model Expense {
  id          String      @id @default(cuid())
  branchId    String
  branch      Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  type        ExpenseType  @default(OPERATIONAL)
  amount      Decimal     @db.Decimal(12, 2)
  category    String      // RENT, SALARY, LUNCH, SUPPLIER, EKUB, UTILITIES, OTHER
  description String?
  date        DateTime    @db.Date
  createdAt   DateTime    @default(now())

  @@index([branchId, date])
  @@index([userId])
}

model Loan {
  id               String     @id @default(cuid())
  branchId         String
  branch           Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  type             LoanType   // EMPLOYEE => userId; CUSTOMER => entityId (customer name/phone)
  entityId         String?    // For CUSTOMER loans (customer identifier)
  userId           String?    // For EMPLOYEE loans (the user/employee who borrowed)
  user             User?     @relation("EmployeeLoans", fields: [userId], references: [id], onDelete: SetNull)
  totalAmount      Decimal    @db.Decimal(12, 2)
  remainingBalance Decimal    @db.Decimal(12, 2)
  status           LoanStatus @default(OPEN)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  payments         LoanPayment[]

  @@index([branchId])
}

model LoanPayment {
  id        String   @id @default(cuid())
  loanId    String
  loan      Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  amountPaid Decimal @db.Decimal(12, 2)
  date      DateTime @db.Date
  createdAt DateTime @default(now())
}

model Penalty {
  id         String   @id @default(cuid())
  userId     String   // User (staff) the penalty applies to
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount     Decimal  @db.Decimal(12, 2)
  reason     String
  date       DateTime @db.Date
  isDeducted Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
}

model PayrollRecord {
  id                String   @id @default(cuid())
  userId            String   // User (staff) this payroll is for
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month             Int
  year              Int
  baseSalary        Decimal  @db.Decimal(12, 2)
  loanDeductions    Decimal  @db.Decimal(12, 2) @default(0)
  penaltyDeductions Decimal  @db.Decimal(12, 2) @default(0)
  bonus             Decimal  @db.Decimal(12, 2) @default(0)
  finalAmount       Decimal  @db.Decimal(12, 2)
  paymentDate       DateTime?
  createdAt         DateTime @default(now())
  @@unique([userId, month, year])
}
